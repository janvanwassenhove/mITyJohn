---
// Blog post layout — not designed (gap-list G1/G9 context): built from the design's
// type system. Title block, mono meta line (date + tags), prose body. No comments:
// D4 specified Giscus, but Jan dropped comments for the new site, so the scaffold
// went with them. See the correction note on D4 in MIGRATION_BRIEF.md.
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';
import imageDims from '../data/image-dims.json';

interface Props { post: CollectionEntry<'blog'> }
const { post } = Astro.props;
const { title, date, tags, cover, ogImage } = post.data;
const fmt = date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
// Same rule as the markdown images (astro.config): size from the WordPress
// `-WxH` suffix, else the measured lookup. The cover is the LCP element, so it
// must reserve its box before it loads.
const suffix = cover?.match(/-(\d+)x(\d+)\.\w+$/);
const coverDims = suffix
  ? [suffix[1], suffix[2]]
  : (cover ? (imageDims as Record<string, number[] | undefined>)[cover.split('?')[0]] : undefined);
---

<Base title={`${title} — mITy.John`} ogImage={ogImage ?? cover} ogType="article">
  <article>
    <header>
      <div class="meta">
        <time datetime={date.toISOString()}>{fmt}</time>
        {tags.map((t) => <a class="tag" href={`/tags/${t}/`}>#{t}</a>)}
      </div>
      <h1>{title}</h1>
      {cover && (
        <img
          class="cover"
          src={cover}
          alt=""
          fetchpriority="high"
          width={coverDims?.[0]}
          height={coverDims?.[1]}
        />
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

<style>
  article { max-width: 820px; margin: 0 auto; padding: clamp(40px, 6vw, 72px) var(--section-pad-x) var(--section-pad-y); }
  .meta { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; font-family: var(--font-mono); font-size: var(--text-caption); color: var(--muted2); margin-bottom: 18px; }
  .tag { color: var(--accent); }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(30px, 4.6vw, 52px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: var(--tracking-display);
    margin: 0 0 26px;
    text-wrap: balance;
  }
  .cover { width: 100%; border-radius: var(--radius-card); border: 1px solid var(--border); margin-bottom: 8px; }
  .prose { margin-top: clamp(24px, 3vw, 36px); }
</style>
