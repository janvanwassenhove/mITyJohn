---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = 'mITy.John — a one-person lab exploring where software has been and where it is going. Apps, music, books and one gloriously unnecessary programming language.',
  ogImage = '/wp-content/uploads/2023/12/logo_title.png',
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="mITy.John" href="/rss.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    {/* Fonts are self-hosted (scripts/fetch-fonts.mjs) — no third-party requests.
        Preload just the two faces used above the fold. */}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/space-grotesk-700-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/ibm-plex-sans-400-latin.woff2" crossorigin />
    <script is:inline>
      // Theme init — before paint to avoid flash. Dark is default (design).
      (() => {
        try {
          const t = localStorage.getItem('mityTheme');
          if (t === 'light') document.documentElement.dataset.theme = 'light';
        } catch {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />

    {/* Book previews open here instead of downloading the PDF. */}
    <dialog id="pdf-viewer" aria-label="Book preview">
      <div class="pdf-bar">
        <span class="pdf-title"></span>
        <span class="pdf-actions">
          <a class="pdf-buy" href="#" target="_blank" rel="noopener">Buy on Amazon ↗</a>
          <a class="pdf-open" href="#" target="_blank" rel="noopener">Open in new tab ↗</a>
          <button class="pdf-close" type="button" aria-label="Close preview">✕</button>
        </span>
      </div>
      <div class="pdf-frame"></div>
    </dialog>
    <script>
      // Click-to-load third-party embeds in converted content (§8.1, D5). The
      // provider is contacted only after the visitor clicks; sandboxed so an
      // embed cannot navigate this page (the eager Spotify iframe used to).
      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.embed-facade') as HTMLElement | null;
        if (!btn) return;
        const f = document.createElement('iframe');
        f.src = btn.dataset.embedSrc!;
        f.title = btn.querySelector('.ef-title')?.textContent ?? 'Embedded player';
        f.loading = 'lazy';
        f.allow = 'autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture';
        f.setAttribute('sandbox', 'allow-scripts allow-same-origin allow-presentation allow-popups');
        f.style.cssText = `display:block;width:100%;height:${btn.dataset.embedH || 352}px;border:0;border-radius:var(--radius-embed);margin:1.6em 0;`;
        btn.replaceWith(f);
      });
    </script>
    <script>
      // Book preview lightbox: render the teaser PDF inline rather than letting the
      // browser download it. The iframe is only created on open.
      {
        const dlg = document.getElementById('pdf-viewer') as HTMLDialogElement | null;
        const frame = dlg?.querySelector('.pdf-frame') as HTMLElement | null;
        const titleEl = dlg?.querySelector('.pdf-title') as HTMLElement | null;
        const openLink = dlg?.querySelector('.pdf-open') as HTMLAnchorElement | null;
        const buyLink = dlg?.querySelector('.pdf-buy') as HTMLAnchorElement | null;

        const close = () => {
          dlg?.close();
          if (frame) frame.replaceChildren();
        };

        document.addEventListener('click', (e) => {
          const btn = (e.target as HTMLElement).closest('[data-pdf]') as HTMLElement | null;
          if (!btn || !dlg || !frame) return;
          const src = btn.dataset.pdf!;
          if (titleEl) titleEl.textContent = btn.dataset.pdfTitle ?? 'Preview';
          if (openLink) openLink.href = src;
          if (buyLink) {
            const buy = btn.dataset.pdfBuy;
            buyLink.href = buy ?? '#';
            buyLink.hidden = !buy;
          }

          // Desktop browsers render PDFs in an iframe; mobile ones mostly refuse,
          // so there we show the first-page render and let the button open the file.
          const canEmbed = window.matchMedia('(min-width: 820px)').matches;
          if (canEmbed) {
            const f = document.createElement('iframe');
            f.src = src;
            f.title = (btn.dataset.pdfTitle ?? 'Book') + ' preview';
            frame.replaceChildren(f);
          } else {
            const img = document.createElement('img');
            img.src = btn.dataset.pdfPoster ?? '';
            img.alt = (btn.dataset.pdfTitle ?? 'Book') + ' — first page of the teaser';
            img.className = 'pdf-poster';
            frame.replaceChildren(img);
          }
          dlg.showModal();
        });

        dlg?.querySelector('.pdf-close')?.addEventListener('click', close);
        // click the backdrop (outside the dialog box) to dismiss
        dlg?.addEventListener('click', (e) => {
          if (e.target === dlg) close();
        });
        dlg?.addEventListener('close', () => frame?.replaceChildren());
      }
    </script>
    <script>
      // Scroll reveal — design behaviour, respects prefers-reduced-motion via CSS.
      const els = document.querySelectorAll('[data-reveal]');
      if (els.length && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              const el = e.target as HTMLElement;
              const sibs = Array.from(el.parentElement?.children ?? []).filter(
                (c) => c.hasAttribute('data-reveal'),
              );
              const d = Math.min(Math.max(0, sibs.indexOf(el)), 7) * 65;
              el.style.setProperty('--reveal-delay', d + 'ms');
              el.classList.add('is-revealed');
              io.unobserve(el);
            }
          },
          { threshold: 0.1, rootMargin: '0px 0px -6% 0px' },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-revealed'));
      }
    </script>
  </body>
</html>
