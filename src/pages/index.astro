---
// Home — the single designed screen. Section order per the export. Also hosts
// the ?p= JS shim (§5.4).
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import AppCard from '../components/AppCard.astro';
import BookCard from '../components/BookCard.astro';
import PostCard from '../components/PostCard.astro';
import ArcadeStrip from '../components/ArcadeStrip.astro';
import ScrumFeature from '../components/ScrumFeature.astro';
import SpotifyEmbed from '../components/SpotifyEmbed.astro';
import InstagramGrid from '../components/InstagramGrid.astro';
import Quotes from '../components/Quotes.astro';
import TalksTimeline from '../components/TalksTimeline.astro';
import { getCollection } from 'astro:content';
import urlMap from '../../url-map.json';
import talks from '../data/talks.json';
import insta from '../data/instagram.json';

const apps = (await getCollection('apps')).sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));
const books = (await getCollection('books')).sort((a, b) => a.data.order - b.data.order);
const allPosts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const posts = allPosts.slice(0, 8); // two rows of four on the home grid

// "New" is a cross-cutting filter (data-new), not a category — an app is music
// *and* new, so it cannot live in the same field as cat.
const filters = [
  { id: 'all', label: 'All' },
  { id: 'new', label: `New (${apps.filter((a) => a.data.isNew).length})` },
  { id: 'music', label: 'Music' },
  { id: 'games', label: 'Games' },
  { id: 'fun', label: 'Fun' },
  { id: 'lab', label: 'Lab' },
];

const inPrint = books.filter((b) => b.data.series !== 'Coming soon').length;

const stats = [
  { n: String(apps.length), label: 'apps in the lab' },
  { n: String(allPosts.length), label: 'field notes filed' },
  { n: String(inPrint), label: 'books in print' },
  { n: '60+', label: 'years of IT dug up' },
  { n: '1', label: 'suspiciously helpful robot' },
  { n: '0', label: 'cookies served' }, // true as well as funny: analytics here are cookieless
];

// Hero level selector — every level, with a live count so the numbers can't go stale.
// Ordered by what a first-time visitor is most likely to want: the things you
// can buy or verify first, the personal projects after. Books and Talks used to
// sit at 04/05 behind SPL and the Spotify embed.
const levels = [
  { no: '01', label: 'Apps', section: 'The store', href: '#apps', count: `${apps.length} apps`, accent: 'var(--level-store)', ink: 'var(--ink-on-accent)' },
  { no: '02', label: 'Books', section: 'The bookstore', href: '#books', count: `${inPrint} editions`, accent: 'var(--level-books)', ink: 'var(--ink-on-level-books)' },
  { no: '03', label: 'Talks', section: 'The stage', href: '/talks/', count: `${talks.length} talks`, accent: 'var(--level-stage)', ink: 'var(--ink-on-level-stage)' },
  { no: '04', label: 'Blog', section: 'Field notes', href: '/blog/', count: `${allPosts.length} posts`, accent: 'var(--level-notes)', ink: 'var(--ink-on-level-notes)' },
  // Subtitle says what it is rather than repeating the level's arcade name —
  // "Sprint zero" read like a project phase, not a programming language.
  // count uses the language's own keyword — short enough not to crowd the
  // two-line subtitle, and it says what SPL compiles from
  { no: '05', label: 'Scrum', section: 'Programming language', href: '#scrum', count: '#INTENT', accent: 'var(--level-scrum)', ink: 'var(--ink-on-level-scrum)' },
  { no: '06', label: 'Artist', section: 'The artist', href: '#artist', count: 'Press play', accent: 'var(--level-artist)', ink: 'var(--ink-on-accent-2)' },
  { no: '07', label: 'Insta', section: 'The dig', href: '#dig', count: `${insta.length} finds`, accent: 'var(--level-dig)', ink: 'var(--ink-on-level-dig)' },
  { no: '08', label: 'About', section: 'The archeologist', href: '/about/', count: '1 human', accent: 'var(--muted)', ink: 'var(--bg)' },
];

// §5.4 JS shim — compact map inlined from url-map.json (belt and braces under §5.3).
const shim: Record<string, Record<string, string> | string> = { p: {}, page_id: {}, tag: {}, cat: {}, category_name: {}, feed: '/rss.xml', author: {} };
for (const e of urlMap) {
  const m = e.old.match(/^\/\?(p|page_id|tag|cat|category_name|author)=(.+)$/);
  if (m) (shim[m[1]] as Record<string, string>)[m[2]] = e.new;
}
---

<Base title="mITy.John — the software archeologist's lab">
  <script is:inline define:vars={{ shim }}>
    // §5.4 — legacy WordPress query-string shim. Runs before paint; Cloudflare
    // Bulk Redirects (§5.3) are the primary mechanism, this covers the rest.
    (() => {
      const q = new URLSearchParams(location.search);
      for (const k of ['p', 'page_id', 'tag', 'cat', 'category_name', 'author']) {
        const v = q.get(k);
        if (v && shim[k] && shim[k][v]) return location.replace(shim[k][v]);
      }
      if (q.get('feed')) return location.replace(shim.feed);
    })();
  </script>

  <div id="top"></div>

  <!-- ===== HERO ===== -->
  <header class="hero">
    <div data-reveal class="status">
      <span class="dot"></span>
      the software archeologist&rsquo;s lab
    </div>
    <h1 data-reveal>
      Knowing our past<br />helps us build
      <span class="hl">what&rsquo;s next<span class="cursor mj-anim"></span></span>
    </h1>
    <p data-reveal class="lead">
      A one-person lab, digging up where software has been to work out where it&rsquo;s going.
      What happens when curiosity gets root access: apps, picture books, essays, and one
      <em>gloriously</em> unnecessary programming language.<br /><br />
      <span class="hl">Now with 100% more &ldquo;why did he build that?&rdquo;</span>
    </p>
    <div data-reveal class="levels">
      {levels.map((l) => (
        <a class="level-btn" href={l.href} style={`--lv:${l.accent};--lv-ink:${l.ink};`}>
          <span class="lv-no">{l.no}</span>
          <span class="lv-body">
            <span class="lv-label">{l.label}</span>
            <span class="lv-sub">{l.section}</span>
            <span class="lv-count">{l.count}</span>
          </span>
        </a>
      ))}
    </div>
    <div data-reveal class="stats">
      {stats.map((s) => (
        <div class="stat">
          <div class="n">{s.n}</div>
          <div class="l">{s.label}</div>
        </div>
      ))}
    </div>
  </header>

  <ArcadeStrip variant="store" />

  <!-- ===== APPS STORE ===== -->
  <section id="apps" class="store">
    <div class="store-head">
      <SectionHeader level="01" section="THE STORE" accentVar="var(--level-store)" inkVar="var(--ink-on-accent)" title="Apps from the lab" />
      <p class="store-note">All free. Download a release, launch the web build, or read the source. No cookies, no upsell, no regrets.</p>
    </div>
    <div class="filters" id="app-filters">
      {filters.map((f, i) => (
        <button type="button" data-filter={f.id} class={i === 0 ? 'active' : ''}>{f.label}</button>
      ))}
    </div>
    <div class="grid" id="app-grid">
      {apps.map((app) => <AppCard app={app} />)}
    </div>
  </section>

  <ArcadeStrip variant="books" />

  <!-- ===== BOOKSTORE ===== -->
  <section id="books" class="bookstore">
    <div class="wrap">
      <SectionHeader level="02" section="THE BOOKSTORE" accentVar="var(--level-books)" inkVar="var(--ink-on-level-books)" title="Books, printed & kindled" />
      <p class="books-note">Reimagined classics and picture books the whole family can pretend to understand. Paperback &amp; Kindle on Amazon.</p>
      <div class="grid">
        {books.map((b) => <BookCard book={b} />)}
      </div>
    </div>
  </section>

  <ArcadeStrip variant="stage" />

  <!-- ===== SPEAKER (THE STAGE) ===== -->
  <section id="talks" class="stage">
    <div class="stage-head">
      <SectionHeader level="03" section="THE STAGE" accentVar="var(--level-stage)" inkVar="var(--ink-on-level-stage)" title="Talks & conferences" />
      <a class="all" href="/talks/">All {talks.length} talks →</a>
    </div>
    <TalksTimeline limit={4} more="/talks/" />
  </section>

  <ArcadeStrip variant="notes" />

  <!-- ===== BLOG ===== -->
  <section id="blog" class="blog">
    <div class="blog-head">
      <SectionHeader level="04" section="FIELD NOTES" accentVar="var(--level-notes)" inkVar="var(--ink-on-level-notes)" title="Latest from the blog" />
      <a class="all" href="/blog/">All posts →</a>
    </div>
    <div class="grid">
      {posts.map((p) => <PostCard post={p} />)}
    </div>
  </section>

  <ArcadeStrip variant="scrum" />

  <!-- ===== SCRUM (SPRINT ZERO) =====
       Deliberate scope addition beyond the original Claude Design export (Jan's
       request, post-launch): promotes SPL from a plain feature banner into a full
       numbered level with its own kart-racing arcade strip. -->
  <section id="scrum" class="lab">
    <SectionHeader level="05" section="SPRINT ZERO" accentVar="var(--level-scrum)" inkVar="var(--ink-on-level-scrum)" title="A language that compiles ceremonies" />
    <ScrumFeature />
  </section>

  <ArcadeStrip variant="artist" />

  <!-- ===== ARTIST ===== -->
  <section id="artist" class="artist">
    <div class="wrap">
      <div data-reveal class="panel">
        <div>
          <SectionHeader level="06" section="THE ARTIST" accentVar="var(--level-artist)" inkVar="var(--ink-on-accent-2)" title="mITy.John, but make it sound" />
          <p class="artist-lead">
            Songs composed with a suspicious amount of AI and a Raspberry Pi that never asked
            for any of this. Press play, judge gently.
          </p>
          <div class="artist-ctas">
            <a class="primary" href="https://open.spotify.com/artist/4lRudVkciTQ8j2bEySXqPz" target="_blank" rel="noopener">Spotify ↗</a>
            <a href="https://soundcloud.com/mityjohn" target="_blank" rel="noopener">SoundCloud ↗</a>
            <a href="/artist/">About the artist</a>
          </div>
        </div>
        <SpotifyEmbed />
      </div>
    </div>
  </section>

  <InstagramGrid />
  <Quotes />
</Base>

<script>
  // Store filter — the design's only store interaction, in a few lines of vanilla JS.
  const root = document.getElementById('app-filters');
  const grid = document.getElementById('app-grid');
  root?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-filter]') as HTMLButtonElement | null;
    if (!btn || !grid) return;
    root.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === btn));
    const f = btn.dataset.filter;
    grid.querySelectorAll<HTMLElement>('[data-cat]').forEach((card) => {
      const show = f === 'all' || (f === 'new' ? card.dataset.new === 'true' : card.dataset.cat === f);
      card.style.display = show ? '' : 'none';
    });
  });
</script>

<style>
  /* HERO */
  .hero { position: relative; overflow: hidden; max-width: var(--container-max); margin: 0 auto; padding: var(--hero-pad-top) var(--section-pad-x) clamp(40px, 6vw, 72px); }
  .status {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border: 1px solid var(--border2);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--muted2);
    margin-bottom: 28px;
  }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--ok); box-shadow: var(--glow-dot-ok); }
  h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-hero);
    line-height: var(--leading-hero);
    letter-spacing: -0.03em;
    margin: 0 0 26px;
    text-wrap: balance;
  }
  .hl { color: var(--accent); position: relative; }
  .cursor { display: inline-block; width: 0.5ch; height: 0.9em; background: var(--accent); margin-left: 6px; vertical-align: -0.06em; animation: blink var(--blink-duration) step-end infinite; }
  .lead { max-width: 620px; font-size: var(--text-lead); line-height: var(--leading-body); color: var(--muted); margin: 0 0 36px; text-wrap: pretty; }
  /* Level selector — one button per level, each carrying its own accent + count */
  .levels {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 10px;
    max-width: 900px;
  }
  .level-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: var(--chip);
    color: var(--text);
    border: 1px solid var(--border2);
    border-left: 3px solid var(--lv);
    border-radius: 10px;
    transition: border-color var(--hover-duration) var(--hover-ease), transform var(--hover-duration) var(--hover-ease), background var(--hover-duration) var(--hover-ease);
  }
  .level-btn:hover {
    border-color: var(--border3);
    border-left-color: var(--lv);
    transform: translateY(-3px);
    color: var(--text);
    background: var(--s2);
  }
  .lv-no {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--lv-ink);
    background: var(--lv);
    border-radius: 6px;
    padding: 3px 7px;
    flex-shrink: 0;
  }
  .lv-body { display: flex; flex-direction: column; flex: 1; min-width: 0; }
  .lv-label { font-family: var(--font-display); font-size: 16px; font-weight: 600; line-height: 1.2; }
  .lv-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted2);
    margin-top: 2px;
    /* wrap at spaces only — `anywhere` split words as BOOKSTO/RE */
    overflow-wrap: normal;
  }
  /* Count sits under the subtitle rather than beside it. Side by side, a subtitle
     that wrapped to two lines collided with it — "PROGRAMMINGBy intent" — and the
     same happened on Books and About. Stacked, the text always has full width. */
  .lv-count {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--muted2);
    margin-top: 6px;
  }
  .level-btn:hover .lv-count { color: var(--lv); }
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1px;
    margin-top: 56px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    overflow: hidden;
  }
  .stat { background: var(--s1); padding: 20px 22px; }
  .stat .n { font-family: var(--font-display); font-size: var(--text-stat); font-weight: 700; color: var(--accent); }
  .stat .l { font-family: var(--font-mono); font-size: var(--text-caption); color: var(--muted2); margin-top: 4px; }

  /* STORE */
  .store { max-width: var(--container-max); margin: 0 auto; padding: var(--section-pad-y) var(--section-pad-x); }
  .store-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; margin-bottom: 8px; }
  .store-note { font-family: var(--font-mono); font-size: var(--text-small); color: var(--muted2); max-width: 320px; margin: 0; }
  .filters { display: flex; flex-wrap: wrap; gap: var(--gap-chips); margin: 28px 0 30px; }
  .filters button {
    cursor: pointer;
    padding: 9px 15px;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 600;
    background: var(--s2);
    color: var(--muted);
    border: 1px solid var(--border);
  }
  .filters button:hover { border-color: var(--border3); }
  .filters button.active { background: var(--accent); color: var(--ink-on-accent); border-color: transparent; }
  .store .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--gap-cards); }

  /* SCRUM / THE LAB (level 02) */
  .lab { max-width: var(--container-max); margin: 0 auto; padding: var(--section-pad-y) var(--section-pad-x); scroll-margin-top: 80px; }

  /* ARTIST */
  .artist { border-top: 1px solid var(--line); background: linear-gradient(180deg, var(--s0), var(--bg)); scroll-margin-top: 70px; }
  .artist .wrap { max-width: var(--container-max); margin: 0 auto; padding: var(--section-pad-y) var(--section-pad-x); }
  .panel {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
    align-items: center;
    background: linear-gradient(120deg, var(--s2), var(--s0));
    border: 1px solid var(--border);
    border-radius: var(--radius-panel-lg);
    padding: var(--panel-pad);
  }
  .artist-lead { font-size: var(--text-body-lg); line-height: var(--leading-relaxed); color: var(--muted); margin: 0 0 22px; text-wrap: pretty; }
  .artist-ctas { display: flex; flex-wrap: wrap; gap: 10px; }
  .artist-ctas a {
    padding: 11px 18px;
    border: 1px solid var(--border2);
    border-radius: var(--radius-btn);
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--text);
  }
  .artist-ctas a:hover { border-color: var(--border3); }
  .artist-ctas a.primary { background: var(--accent); color: var(--ink-on-accent); border-color: transparent; font-weight: 600; }
  .artist-ctas a.primary:hover { filter: brightness(1.08); }

  /* BOOKSTORE */
  .bookstore { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: linear-gradient(180deg, var(--s0), var(--bg)); }
  .bookstore .wrap { max-width: var(--container-max); margin: 0 auto; padding: var(--section-pad-y) var(--section-pad-x); }
  .books-note { font-family: var(--font-mono); font-size: var(--text-small); color: var(--muted2); max-width: 460px; margin: 10px 0 36px; }
  .bookstore .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--gap-books); }

  /* SPEAKER / THE STAGE (level 05) */
  .stage { max-width: var(--container-max); margin: 0 auto; padding: var(--section-pad-y) var(--section-pad-x); scroll-margin-top: 80px; }
  .stage-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; margin-bottom: 30px; }

  /* BLOG */
  .blog { max-width: var(--container-max); margin: 0 auto; padding: var(--section-pad-y) var(--section-pad-x); }
  .blog-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; margin-bottom: 30px; }
  .all {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    padding: 10px 16px;
    border: 1px solid var(--border2);
    border-radius: var(--radius-btn-sm);
    white-space: nowrap;
  }
  .all:hover { border-color: var(--border3); }
  /* four across on wide screens (two rows of four), degrading to 3/2/1 */
  .blog .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: var(--gap-cards); }
  @media (min-width: 1100px) { .blog .grid { grid-template-columns: repeat(4, 1fr); } }
</style>
