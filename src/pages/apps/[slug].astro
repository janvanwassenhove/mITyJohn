---
// App detail — gap-list G1: authored from designed precedents (card header art +
// action row over the prose Page layout). Version / release info from releases.json
// when the app has a repo with releases (§9); otherwise the designed fallback CTAs.
import Base from '../../layouts/Base.astro';
import ArcadeStrip from '../../components/ArcadeStrip.astro';
import { getCollection, render } from 'astro:content';
import releases from '../../data/releases.json';

export async function getStaticPaths() {
  const apps = await getCollection('apps');
  return apps.map((app) => ({ params: { slug: app.id }, props: { app } }));
}

const { app } = Astro.props;
const { Content } = await render(app);
const { name, code, tag, blurb, repo, demoUrl, cat } = app.data;

type Asset = { name: string; url: string; size: number; platform?: string };
type Release = { tag?: string; date?: string; assets?: Asset[] };
const rel: Release | undefined = repo ? (releases as Record<string, Release>)[repo] : undefined;
const gh = repo ? `https://github.com/janvanwassenhove/${repo}` : undefined;
const fmtSize = (b: number) => (b > 1048576 ? (b / 1048576).toFixed(1) + ' MB' : Math.round(b / 1024) + ' KB');
---

<Base title={`${name} — mITy.John`} description={blurb}>
  <ArcadeStrip variant={cat === 'lab' ? 'scrum' : 'store'} />
  <article>
    <header class="hero-card">
      <div class="scan"></div>
      <div class="art"><span class="code">{code}</span></div>
      <div class="text">
        <div class="meta">
          <span class="tag">{tag}</span>
          {rel?.tag && <span class="version">{rel.tag}</span>}
          {rel?.date && <span class="date">{new Date(rel.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}</span>}
        </div>
        <h1>{name}</h1>
        <p>{blurb}</p>
        <div class="actions">
          {rel?.assets?.length
            ? <a class="primary" href={rel.assets[0].url}>Download {rel.assets[0].name} ({fmtSize(rel.assets[0].size)})</a>
            : gh && <a class="primary" href={`${gh}/releases`} target="_blank" rel="noopener">Get ↓</a>}
          {demoUrl && <a href={demoUrl} target="_blank" rel="noopener">{cat === 'games' ? 'Play ↗' : 'Web ↗'}</a>}
          {gh && <a href={gh} target="_blank" rel="noopener">Code</a>}
        </div>
        {rel?.assets && rel.assets.length > 1 && (
          <div class="assets">
            {rel.assets.slice(1).map((a) => (
              <a href={a.url}>{a.platform ? `${a.platform} · ` : ''}{a.name} ({fmtSize(a.size)})</a>
            ))}
          </div>
        )}
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  article { max-width: 820px; margin: 0 auto; padding: clamp(40px, 6vw, 72px) var(--section-pad-x) var(--section-pad-y); }
  .hero-card {
    position: relative;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    background: linear-gradient(180deg, var(--s2), var(--s1));
    border: 1px solid var(--border);
    border-radius: var(--radius-card-lg);
    padding: clamp(20px, 3vw, 30px);
    overflow: hidden;
    margin-bottom: clamp(28px, 4vw, 44px);
  }
  .scan { position: absolute; inset: 0 0 auto 0; height: 24px; pointer-events: none; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.03), transparent); animation: scan 4.5s linear infinite; }
  .art { display: flex; align-items: center; justify-content: center; min-width: 120px; }
  .code {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 15px;
    color: var(--accent);
    border: 1px solid var(--border2);
    padding: 10px 16px;
    border-radius: var(--radius-btn-sm);
    background: var(--navbg);
  }
  .text { flex: 1; min-width: 260px; }
  .meta { display: flex; gap: 12px; flex-wrap: wrap; font-family: var(--font-mono); font-size: var(--text-caption-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted2); margin-bottom: 10px; }
  .version { color: var(--accent); border: 1px solid var(--border2); border-radius: var(--radius-pill); padding: 1px 10px; }
  h1 { font-family: var(--font-display); font-size: clamp(26px, 3.6vw, 40px); font-weight: 700; letter-spacing: var(--tracking-display); margin: 0 0 8px; }
  .text > p { font-size: var(--text-body-lg); color: var(--muted); margin: 0 0 18px; text-wrap: pretty; }
  .actions { display: flex; flex-wrap: wrap; gap: 8px; }
  .actions a {
    padding: 10px 16px;
    border-radius: var(--radius-btn-sm);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 600;
    background: var(--chip);
    color: var(--text);
    border: 1px solid var(--border2);
  }
  .actions a:hover { border-color: var(--border3); }
  .actions a.primary { background: var(--accent); color: var(--ink-on-accent); border-color: transparent; }
  .actions a.primary:hover { filter: brightness(1.08); }
  .assets { display: flex; flex-direction: column; gap: 6px; margin-top: 14px; }
  .assets a { font-family: var(--font-mono); font-size: var(--text-caption); color: var(--muted); }
  .assets a:hover { color: var(--text); }
</style>
