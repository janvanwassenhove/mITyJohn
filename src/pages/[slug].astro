---
// Static pages (about, artist) from the pages collection — §5.1 /{slug}/.
import { getCollection, render } from 'astro:content';
import Page from '../layouts/Page.astro';
import Quotes from '../components/Quotes.astro';
import NameOrigin from '../components/NameOrigin.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({ params: { slug: page.id }, props: { page } }));
}

const { page } = Astro.props;
const { Content } = await render(page);

// The name explainer and the quotes belong with the About story too — same
// components as the home page, rendered once here rather than copied. The name
// leads: it is the first thing a stranger wonders about.
const isAbout = page.id === 'about';
---

<Page title={page.data.title} description={page.data.description}>
  {isAbout && <NameOrigin />}
  <Content />
  {isAbout && <Quotes slot="full" />}
</Page>
