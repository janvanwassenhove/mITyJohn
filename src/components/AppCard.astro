---
// Store card — exactly the designed card: header art with code badge + tag,
// name, blurb, action row. Actions derived from frontmatter (gap-list G1 note).
import type { CollectionEntry } from 'astro:content';
import shots from '../data/screenshots.json';

interface Props {
  app: CollectionEntry<'apps'>;
  releases?: Record<string, { downloadUrl?: string }>;
}
const { app } = Astro.props;
const { name, code, tag, cat, blurb, repo, demoUrl, isNew } = app.data;

// Real UI screenshots pulled from the app's GitHub repo (scripts/fetch-screenshots.mjs).
// Apps without any fall back to the design's hatched placeholder.
const gallery = ((shots as Record<string, { src: string; alt: string }[]>)[app.id] ?? []).slice(0, 4);

const gh = (r: string) => `https://github.com/janvanwassenhove/${r}`;
type Action = { label: string; href: string; primary?: boolean; external?: boolean };
const actions: Action[] = [];
if (repo) actions.push({ label: 'Get ↓', href: `${gh(repo)}/releases`, primary: true, external: true });
if (demoUrl) actions.push({ label: actions.length === 0 ? (cat === 'games' ? 'Play ↗' : 'Web ↗') : cat === 'games' ? 'Play ↗' : 'Web ↗', href: demoUrl, primary: actions.length === 0, external: true });
if (repo) actions.push({ label: 'Code', href: gh(repo), external: true });
actions.push({ label: 'Info', href: `/apps/${app.id}/` });
---

<div class="card" data-reveal data-cat={cat} data-new={String(isNew)}>
  <div
    class={`art${gallery.length ? ' has-shot' : ''}`}
    data-gallery={gallery.length > 1 ? JSON.stringify(gallery.slice(1).map((s) => s.src)) : undefined}
  >
    {/* Only the first shot ships in the HTML — the rest are fetched on hover, so
        the store grid costs 9 small images instead of 23 (N5 mobile budget). */}
    {gallery[0] && (
      <img
        class="shot active"
        src={gallery[0].src}
        alt={`${name} screenshot`}
        width="560"
        height="315"
        loading="lazy"
        decoding="async"
      />
    )}
    <div class="scan"></div>
    {isNew && <span class="new-flag">NEW</span>}
    <div class="code">{code}</div>
    <div class="tag">{tag}</div>
    {gallery.length > 1 && (
      <div class="dots">
        {gallery.map((_, i) => <span class={i === 0 ? 'on' : ''}></span>)}
      </div>
    )}
  </div>
  <div class="body">
    <h3>{name}</h3>
    <p>{blurb}</p>
    <div class="actions">
      {actions.map((a) => (
        <a
          href={a.href}
          class={a.primary ? 'primary' : ''}
          target={a.external ? '_blank' : undefined}
          rel={a.external ? 'noopener' : undefined}
        >{a.label}</a>
      ))}
    </div>
  </div>
</div>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, var(--s2), var(--s1));
    border: 1px solid var(--border);
    border-radius: var(--radius-card-lg);
    overflow: hidden;
    transition: transform var(--hover-duration) var(--hover-ease), border-color var(--hover-duration) var(--hover-ease), box-shadow var(--hover-duration) var(--hover-ease);
  }
  .card:hover { border-color: var(--border3); transform: translateY(-6px); box-shadow: var(--shadow-card-hover); }
  .art {
    position: relative;
    height: 152px;
    background: repeating-linear-gradient(135deg, #1b1815 0 12px, #171410 12px 24px);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  :root[data-theme='light'] .art { background: repeating-linear-gradient(135deg, #e9e3d4 0 12px, #efeadd 12px 24px); }
  /* Screenshot gallery: crossfade between shots on hover, code badge stays legible */
  .shot {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .shot.active { opacity: 1; }
  .art.has-shot::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(13, 12, 11, 0.55), rgba(13, 12, 11, 0.15) 45%, rgba(13, 12, 11, 0.7));
  }
  .art.has-shot .code, .art.has-shot .tag, .art.has-shot .dots { z-index: 2; }
  .art.has-shot .code { background: rgba(13, 12, 11, 0.72); }
  /* top-right corner flag on the card art */
  .new-flag {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 3;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--ink-on-accent);
    background: var(--accent);
    border-radius: var(--radius-pill);
    padding: 3px 9px;
    box-shadow: 0 4px 14px -4px var(--accent);
  }
  .dots { position: absolute; bottom: 10px; right: 12px; display: flex; gap: 5px; }
  .dots span { width: 5px; height: 5px; border-radius: 50%; background: var(--muted2); opacity: 0.5; transition: opacity 0.3s ease, background 0.3s ease; }
  .dots span.on { background: var(--accent); opacity: 1; }
  .scan {
    position: absolute;
    inset: 0 0 auto 0;
    height: 24px;
    pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.03), transparent);
    animation: scan 4.5s linear infinite;
  }
  .code {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 15px;
    color: var(--accent);
    border: 1px solid var(--border2);
    padding: 8px 14px;
    border-radius: var(--radius-btn-sm);
    background: var(--navbg);
  }
  .tag {
    position: absolute;
    top: 12px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: var(--text-caption-xs);
    color: var(--muted2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .body { padding: 18px 18px 20px; display: flex; flex-direction: column; flex: 1; }
  h3 { font-family: var(--font-display); font-size: var(--text-card-title); font-weight: 600; margin: 0 0 7px; letter-spacing: -0.01em; }
  p { font-size: var(--text-body); line-height: var(--leading-body); color: var(--muted); margin: 0 0 16px; flex: 1; text-wrap: pretty; }
  .actions { display: flex; flex-wrap: wrap; gap: 8px; }
  .actions a {
    padding: 8px 12px;
    border-radius: var(--radius-btn-sm);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 600;
    background: var(--chip);
    color: var(--text);
    border: 1px solid var(--border2);
  }
  .actions a:hover { border-color: var(--border3); }
  .actions a.primary { background: var(--accent); color: var(--ink-on-accent); border-color: transparent; }
  .actions a.primary:hover { filter: brightness(1.08); border-color: transparent; }
</style>

<script>
  // Cycle a card's screenshots while the pointer is over it. The extra shots are
  // fetched on first hover, so they cost nothing on initial load.
  document.querySelectorAll<HTMLElement>('.card .art[data-gallery]').forEach((art) => {
    const rest: string[] = JSON.parse(art.dataset.gallery || '[]');
    const dots = [...art.querySelectorAll<HTMLElement>('.dots span')];
    let shots = [...art.querySelectorAll<HTMLElement>('.shot')];
    let i = 0;
    let timer: number | undefined;
    let hydrated = false;

    const hydrate = () => {
      if (hydrated) return;
      hydrated = true;
      for (const src of rest) {
        const img = document.createElement('img');
        img.className = 'shot';
        img.src = src;
        img.alt = '';
        img.decoding = 'async';
        art.insertBefore(img, art.querySelector('.scan'));
      }
      shots = [...art.querySelectorAll<HTMLElement>('.shot')];
    };

    const show = (n: number) => {
      shots[i]?.classList.remove('active');
      dots[i]?.classList.remove('on');
      i = n % shots.length;
      shots[i]?.classList.add('active');
      dots[i]?.classList.add('on');
    };

    const card = art.closest('.card')!;
    card.addEventListener('mouseenter', () => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      hydrate();
      timer = window.setInterval(() => show(i + 1), 1400);
    });
    card.addEventListener('mouseleave', () => {
      window.clearInterval(timer);
      show(0);
    });
  });
</script>
