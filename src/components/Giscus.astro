---
// Giscus comments (D4) — blog posts only, lazy, below the fold, never render-blocking.
// Discussions are enabled and the IDs below are real (fetched via the GitHub API).
// LAST STEP (Jan): install https://github.com/apps/giscus on the repo, then flip
// ENABLED to true — without the app installed the widget would show an error box.
const ENABLED = false; // TODO(Jan): flip after installing the giscus app
const REPO = 'janvanwassenhove/mITyJohn';
const REPO_ID = 'R_kgDOTcsZDQ';
const CATEGORY = 'General';
const CATEGORY_ID = 'DIC_kwDOTcsZDc4DBe4b';
const configured = ENABLED && REPO_ID !== '' && CATEGORY_ID !== '';
---

{configured && (
  <div class="comments">
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo={REPO}
      data-repo-id={REPO_ID}
      data-category={CATEGORY}
      data-category-id={CATEGORY_ID}
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="transparent_dark"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </div>
)}

<style>
  .comments { margin-top: clamp(40px, 6vw, 64px); border-top: 1px solid var(--line); padding-top: clamp(28px, 4vw, 44px); }
</style>
