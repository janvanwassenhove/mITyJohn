---
// Giscus comments (D4) — blog posts only, lazy, below the fold, never render-blocking.
// SETUP (Jan): enable GitHub Discussions on this repo, install the giscus app
// (https://github.com/apps/giscus), then fill REPO_ID and CATEGORY_ID from
// https://giscus.app. The component renders nothing until both are set.
const REPO = 'janvanwassenhove/mITyJohn';
const REPO_ID = ''; // TODO(Jan): from giscus.app
const CATEGORY = 'Announcements';
const CATEGORY_ID = ''; // TODO(Jan): from giscus.app
const configured = REPO_ID !== '' && CATEGORY_ID !== '';
---

{configured && (
  <div class="comments">
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo={REPO}
      data-repo-id={REPO_ID}
      data-category={CATEGORY}
      data-category-id={CATEGORY_ID}
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="transparent_dark"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </div>
)}

<style>
  .comments { margin-top: clamp(40px, 6vw, 64px); border-top: 1px solid var(--line); padding-top: clamp(28px, 4vw, 44px); }
</style>
