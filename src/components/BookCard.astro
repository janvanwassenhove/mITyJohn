---
// Bookstore card — typographic 2/3 cover + description + Buy/Preview CTAs (design verbatim).
import type { CollectionEntry } from 'astro:content';

interface Props { book: CollectionEntry<'books'> }
const { book } = Astro.props;
const { title, series, badge, desc, buy, preview, cover } = book.data;
---

<div class="book" data-reveal>
  <a class={`cover${cover ? ' has-art' : ''}`} href={buy} target="_blank" rel="noopener">
    {cover ? (
      <img src={cover} alt={`Cover of ${title}`} loading="lazy" decoding="async" width="600" height="948" />
    ) : (
      <div class="inner">
        <div class="series">{series}</div>
        <div>
          <div class="title">{title}</div>
          <div class="badge">{badge}</div>
        </div>
      </div>
    )}
  </a>
  <div class="meta">
    <div class="name">{title}</div>
    <p>{desc}</p>
    <div class="ctas">
      <a class="buy" href={buy} target="_blank" rel="noopener">Buy on Amazon</a>
      {preview && (
        <a
          class="preview"
          href={preview}
          target={preview.startsWith('http') ? '_blank' : undefined}
          rel={preview.startsWith('http') ? 'noopener' : undefined}
        >Preview</a>
      )}
    </div>
  </div>
</div>

<style>
  .book { display: flex; flex-direction: column; }
  .cover {
    display: block;
    aspect-ratio: 2 / 3;
    border-radius: var(--radius-cover);
    overflow: hidden;
    border: 1px solid var(--border);
    background: repeating-linear-gradient(160deg, #1b1815 0 14px, #171410 14px 28px);
    position: relative;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  :root[data-theme='light'] .cover { background: repeating-linear-gradient(160deg, #e9e3d4 0 14px, #efeadd 14px 28px); }
  .cover:hover { border-color: var(--accent-2); transform: scale(1.025); }
  /* Real cover art: fill the 2/3 card, no typographic overlay */
  .cover.has-art { background: none; }
  .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .inner { position: absolute; inset: 0; padding: 20px; display: flex; flex-direction: column; justify-content: space-between; }
  .series {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted2);
  }
  .title {
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 700;
    line-height: 1.08;
    color: var(--text);
    margin-bottom: 8px;
    text-wrap: balance;
  }
  .badge { font-family: var(--font-mono); font-size: var(--text-caption-xs); color: var(--accent-2); }
  .meta { margin-top: 14px; }
  .name { font-family: var(--font-display); font-size: var(--text-card-title-xs); font-weight: 600; margin-bottom: 5px; }
  p { font-size: var(--text-small); line-height: var(--leading-body); color: var(--muted2); margin: 0 0 12px; text-wrap: pretty; }
  .ctas { display: flex; gap: 8px; }
  .buy {
    flex: 1;
    text-align: center;
    padding: 9px 12px;
    background: var(--accent-2);
    color: var(--ink-on-accent-2);
    border-radius: var(--radius-btn-sm);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 600;
  }
  .buy:hover { filter: brightness(1.08); color: var(--ink-on-accent-2); }
  .preview {
    padding: 9px 12px;
    border: 1px solid var(--border2);
    border-radius: var(--radius-btn-sm);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--text);
  }
  .preview:hover { border-color: var(--border3); }
</style>
