---
// SPL feature card — "the lab's flagship experiment". Rendered inside the Scrum
// level section (src/pages/index.astro), which owns the id/container/padding.
---

<a class="scrum-card" data-reveal href="/apps/scrum-programming/">
  <img class="mascot" src="/mascot/scrummy.png" alt="Scrummy, the SCRUM language mascot" width="150" height="150" loading="lazy" decoding="async" />
  <div class="text">
    <div class="kicker">the lab's flagship experiment</div>
    <div class="title">Scrum Programming Language</div>
    <div class="sub">A real language where you code entirely in ceremonies. Yes, really. Sprint zero compiles. Say hello to Scrummy.</div>
  </div>
  <span class="cta">Explore →</span>
</a>

<style>
  .scrum-card {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    background: linear-gradient(120deg, var(--s2), var(--s1));
    border: 1px solid var(--border2);
    border-radius: var(--radius-card-lg);
    padding: 20px clamp(18px, 3vw, 28px);
    color: var(--text);
    margin-top: 8px;
  }
  .scrum-card:hover { border-color: var(--level-scrum); color: var(--text); }
  .mascot {
    width: 88px;
    height: 88px;
    object-fit: contain;
    flex-shrink: 0;
    filter: drop-shadow(0 8px 18px rgba(0, 0, 0, 0.45));
    transition: transform var(--hover-duration) var(--hover-ease);
  }
  .scrum-card:hover .mascot { transform: translateY(-4px) rotate(-4deg); }
  .text { flex: 1; min-width: 220px; }
  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-caption-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--muted2);
    margin-bottom: 6px;
  }
  .title { font-family: var(--font-display); font-size: var(--text-feature); font-weight: 700; letter-spacing: -0.01em; }
  .sub { font-size: var(--text-small); color: var(--muted); margin-top: 4px; text-wrap: pretty; }
  .cta { font-family: var(--font-mono); font-size: var(--text-small); color: var(--level-scrum); white-space: nowrap; }
</style>
