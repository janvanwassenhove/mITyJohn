---
// Decorative arcade divider strips — one mini "level" between sections.
// Motion is pure CSS; a small shared script (bottom) keeps score and handles the
// level-1 stomp. It runs only while a strip is on screen and not at all under
// prefers-reduced-motion. Everything here is aria-hidden.
import { MITYJOHN, ARCHEOLOGIST, ARCHEOLOGIST_B } from './sprites';

interface Props {
  variant: 'store' | 'scrum' | 'artist' | 'books' | 'stage' | 'notes' | 'dig';
}
const { variant } = Astro.props;

const LABELS = {
  store: 'LVL 1 · THE STORE — PLATFORMER · BOSS: LEGACY CODE',
  books: 'LVL 2 · THE BOOKSTORE — DELIVERY ROUND · EVERY DOOR ON THE STREET',
  stage: 'LVL 3 · THE STAGE — DODGE · SURVIVE THE Q&A',
  notes: 'LVL 4 · FIELD NOTES — FIGHTING · BOSS: THE BLANK PAGE',
  scrum: 'LVL 5 · SPRINT ZERO — TIME TRIAL · RIDE THE EPIC, RESOLVE THE INTENT',
  artist: 'LVL 6 · THE ARTIST — RHYTHM · HIT THE NOTES',
  dig: 'LVL 7 · THE DIG — RUNNER · OUTRUN THE BOULDER, GRAB THE RELIC',
};

// --- pixel sprites (box-shadow art on a single element) ---------------------
const RUNNER = MITYJOHN;

// Delivery van for the book round (Paperboy-style), 6px cells.
const VAN = (() => {
  const A = 'var(--level-books)', W = '#efe6d6', D = '#33302b';
  const c: string[] = [];
  const put = (x: number, y: number, col: string) => c.push(`${x * 6}px ${y * 6}px 0 ${col}`);
  for (let x = 0; x <= 4; x++) put(x, 0, A); // box body roof
  for (let x = 0; x <= 6; x++) put(x, 1, A);
  for (let x = 0; x <= 6; x++) put(x, 2, A);
  [5, 6].forEach((x) => put(x, 1, W)); // cab window
  for (let x = 0; x <= 6; x++) put(x, 3, A);
  [1, 5].forEach((x) => put(x, 4, D)); // wheels
  return c.join(', ');
})();

// Boss for level 1: LEGACY CODE — a hulking mainframe with red status eyes.
const BOSS_LEGACY = [
  ...Array.from({ length: 6 }, (_, r) => Array.from({ length: 7 }, (_, c) => `${c * 8}px ${r * 8}px 0 #545a66`)).flat(),
  '8px 8px 0 #1b2027', '16px 8px 0 #1b2027', '24px 8px 0 #1b2027', '32px 8px 0 #1b2027', '40px 8px 0 #1b2027',
  '16px 16px 0 #e05a48', '32px 16px 0 #e05a48',
  '8px 32px 0 #3b414b', '24px 32px 0 #3b414b', '40px 32px 0 #3b414b',
  '8px 24px 0 #e0a44a', '40px 24px 0 #e0a44a',
].join(', ');

// Boss for level 6: THE BLANK PAGE — a blank sheet with a smug cursor.
const BOSS_PAGE = [
  ...Array.from({ length: 6 }, (_, r) => Array.from({ length: 5 }, (_, c) => `${c * 8}px ${r * 8}px 0 #ece7dd`)).flat(),
  '8px 8px 0 #cfc7b8', '16px 8px 0 #cfc7b8', '24px 8px 0 #cfc7b8',
  '8px 24px 0 #cfc7b8', '16px 24px 0 #cfc7b8',
  '32px 16px 0 #7fc99a', // blinking cursor
].join(', ');

// Retro IT hardware the runner hurdles on level 1.
const HARDWARE: Record<string, { art: string; w: number; h: number; label: string }> = {
  tower: {
    w: 24, h: 34, label: 'PC',
    art: [
      ...Array.from({ length: 6 }, (_, r) => Array.from({ length: 4 }, (_, c) => `${c * 6}px ${r * 6}px 0 #cfc3ad`)).flat(),
      '6px 6px 0 #4a443b', '12px 6px 0 #4a443b',
      '6px 18px 0 #4a443b', '12px 18px 0 #4a443b',
      '18px 30px 0 #7fc99a',
    ].join(', '),
  },
  mac: {
    w: 30, h: 34, label: 'MAC',
    art: [
      ...Array.from({ length: 6 }, (_, r) => Array.from({ length: 5 }, (_, c) => `${c * 6}px ${r * 6}px 0 #d9d2c2`)).flat(),
      '6px 6px 0 #1f2a33', '12px 6px 0 #1f2a33', '18px 6px 0 #1f2a33',
      '6px 12px 0 #6fb3c9', '12px 12px 0 #1f2a33', '18px 12px 0 #1f2a33',
      '12px 24px 0 #4a443b', '18px 24px 0 #4a443b',
    ].join(', '),
  },
  floppy: {
    w: 24, h: 24, label: 'DISK',
    art: [
      ...Array.from({ length: 4 }, (_, r) => Array.from({ length: 4 }, (_, c) => `${c * 6}px ${r * 6}px 0 #3a4550`)).flat(),
      '6px 0 0 #c9ccd1', '12px 0 0 #c9ccd1',
      '6px 12px 0 #d9d2c2', '12px 12px 0 #d9d2c2', '6px 18px 0 #d9d2c2', '12px 18px 0 #d9d2c2',
    ].join(', '),
  },
};

// Guitar Hero fret colours + lanes (level 3).
const FRETS = ['#7fc99a', '#e05a48', '#e0c04a', '#6fb3c9', '#e08a4a'];
const LANE_Y = [52, 70, 88, 106, 124];
const GEMS: [number, number][] = [
  [0, 0], [2, 0.7], [4, 1.4], [1, 2.1], [3, 2.8], [0, 3.5], [2, 4.2], [4, 4.9], [1, 5.6], [3, 6.3],
];

// Level 2, Temple Run style: the track runs away from the camera and the
// ceremonies rush toward you. Each item starts small and far, scales up as it
// arrives. `lane` is -1 | 0 | 1 (left / centre / right of the track).
const RUNWAY: { kind: 'epic' | 'story' | 'intent'; label: string; lane: -1 | 0 | 1; delay: number }[] = [
  { kind: 'epic', label: 'EPIC "Reporting"', lane: 0, delay: 0 },
  { kind: 'intent', label: '#INTENT', lane: -1, delay: 1.15 },
  { kind: 'story', label: 'USER STORY "Totals"', lane: 1, delay: 2.3 },
  { kind: 'intent', label: '#INTENT', lane: 0, delay: 3.45 },
  { kind: 'story', label: 'USER STORY "Export"', lane: -1, delay: 4.6 },
  { kind: 'epic', label: 'END OF EPIC', lane: 1, delay: 5.75 },
];

// Level 4 roadside dressing: trees, a lamp post and someone waving the van past.
const SCENERY: { at: string; kind: 'tree' | 'lamp' | 'bush' }[] = [
  { at: '8%', kind: 'tree' },
  { at: '26%', kind: 'bush' },
  { at: '43%', kind: 'lamp' },
  { at: '61%', kind: 'tree' },
  { at: '80%', kind: 'bush' },
  { at: '95%', kind: 'tree' },
];

const coins = variant === 'store' ? ['28%', '54%', '79%'] : [];
const obstacles: { at: string; kind: keyof typeof HARDWARE }[] = [
  { at: '36%', kind: 'tower' },
  { at: '62%', kind: 'mac' },
  { at: '86%', kind: 'floppy' },
];
// Houses on the book round; the van throws a parcel at each door.
const HOUSES = ['16%', '34%', '52%', '70%', '88%'];
---

<div class="strip mj-anim" data-mj-strip={variant} aria-hidden="true">
  <div class="label">{LABELS[variant]}</div>
  <div class="score" data-mj-score>SCORE 000000</div>
  <div class="pop" data-mj-pop>+100</div>
  {variant !== 'artist' && variant !== 'scrum' && <div class="ground"></div>}

  {variant === 'store' && (
    <>
      {coins.map((left, i) => (
        <div class="coin" data-mj-collect style={`left:${left};bottom:${70 + (i % 2) * 8}px;animation-delay:${i * 0.5}s;`}>◉</div>
      ))}
      {obstacles.map(({ at, kind }) => (
        <div class="obstacle" style={`left:${at};width:${HARDWARE[kind].w}px;height:${HARDWARE[kind].h}px;`}>
          <div class="sprite" style={`box-shadow:${HARDWARE[kind].art};`}></div>
          <span class="obstacle-tag">{HARDWARE[kind].label}</span>
        </div>
      ))}
      <div class="boss legacy" data-mj-boss>
        <div class="sprite" style={`box-shadow:${BOSS_LEGACY};`}></div>
        <span class="boss-tag">LEGACY CODE</span>
        <span class="debris">{Array.from({ length: 8 }, (_, i) => <i style={`--a:${i * 45}deg;`}></i>)}</span>
        <span class="ko">K.O.</span>
      </div>
    </>
  )}

  {/* LVL 2 — Temple Run down the sprint: the track recedes to a vanishing point,
      ceremonies rush the camera, mITyJohn sprints and grabs the #INTENT */}
  {variant === 'scrum' && (
    <>
      <div class="track">
        <span class="rail left"></span>
        <span class="rail right"></span>
        {Array.from({ length: 7 }, (_, i) => (
          <span class="tie" style={`animation-delay:${i * 0.4}s;`}></span>
        ))}
      </div>
      <div class="sprint-tag">SPRINT</div>
      {RUNWAY.map((c) => (
        <div
          class={`onrush ${c.kind}`}
          data-mj-beat={c.kind === 'intent' ? true : undefined}
          style={`--lane:${c.lane};animation-delay:${c.delay}s;`}
        >{c.label}</div>
      ))}
      <div class="sprinter">
        <div class="sprite frame-a" style={`box-shadow:${RUNNER};`}></div>
        <div class="sprite frame-b" style={`box-shadow:${RUNNER};`}></div>
      </div>
    </>
  )}

  {/* LVL 3 — notes travel to the guitarist and are struck at the cross section */}
  {variant === 'artist' && (
    <>
      {LANE_Y.map((y, i) => (
        <div class="lane" style={`top:${y}px;--fret:${FRETS[i]};`}></div>
      ))}
      <div class="strike"></div>
      <div class="strike-label">HIT</div>
      {LANE_Y.map((y, i) => (
        <div class="fret" style={`top:${y - 5}px;--fret:${FRETS[i]};`}></div>
      ))}
      {GEMS.map(([lane, delay]) => (
        <div class="gem" data-mj-beat style={`top:${LANE_Y[lane] - 6}px;--fret:${FRETS[lane]};animation-delay:${delay}s;`}></div>
      ))}
      <div class="guitarist">
        <div class="sprite" style={`box-shadow:${RUNNER};`}></div>
        <div class="guitar">
          <span class="neck"></span>
          <span class="body"></span>
          <span class="strum"></span>
        </div>
      </div>
    </>
  )}

  {/* LVL 4 — Paperboy-style round: the van drives past and lobs a book at each door */}
  {variant === 'books' && (
    <>
      {SCENERY.map((s) => <div class={`scenery ${s.kind}`} style={`left:${s.at};`}></div>)}
      {HOUSES.map((left, i) => (
        <div class="house" style={`left:${left};`}>
          <span class="roof"></span>
          <span class="door"></span>
          <span class="parcel" data-mj-beat style={`animation-delay:${i * 1.4}s;`}>❏</span>
        </div>
      ))}
      {/* neighbour waving the van past */}
      <div class="waver">
        <span class="body"></span>
        <span class="head"></span>
        <span class="arm"></span>
      </div>
      <div class="van">
        <div class="sprite" style={`box-shadow:${VAN};`}></div>
      </div>
    </>
  )}

  {/* LVL 5 — speaker centre stage, dodging what the room throws */}
  {variant === 'stage' && (
    <>
      <div class="spotlight"></div>
      <div class="heckle from-left" data-mj-beat style="top:66px;animation-duration:3.4s;">?</div>
      <div class="heckle from-left" data-mj-beat style="top:104px;animation-duration:4.1s;animation-delay:1.6s;">?</div>
      <div class="heckle from-right" data-mj-beat style="top:82px;animation-duration:3.8s;animation-delay:0.8s;">🍅</div>
      <div class="heckle from-right" data-mj-beat style="top:118px;animation-duration:4.6s;animation-delay:2.4s;">?</div>
      <div class="mic"></div>
      <div class="audience">
        {Array.from({ length: 14 }, (_, i) => <span style={`animation-delay:${(i % 5) * 0.3}s;`}></span>)}
      </div>
      {/* the speaker himself — sidesteps at the mic while the room throws things */}
      <div class="runner speaker">
        <div class="sprite" style={`box-shadow:${RUNNER};`}></div>
      </div>
    </>
  )}

  {/* LVL 6 — actual fight: trade blows with the blank page until it folds */}
  {variant === 'notes' && (
    <>
      {/* ringside: a crowd of onlookers, stage lights and a hanging banner */}
      <div class="crowd">
        {Array.from({ length: 16 }, (_, i) => (
          <span class={i % 3 === 0 ? 'tall' : ''} style={`animation-delay:${(i % 4) * 0.25}s;`}></span>
        ))}
      </div>
      <div class="ring-light" style="left:22%;"></div>
      <div class="ring-light" style="left:50%;animation-delay:0.6s;"></div>
      <div class="ring-light" style="left:78%;animation-delay:1.2s;"></div>
      <div class="banner">ROUND 1 · WRITE SOMETHING</div>
      <div class="hp you">mITy JOHN<div class="bar"><div class="fill ok"></div></div></div>
      <div class="hp boss-hp">THE BLANK PAGE<div class="bar"><div class="fill danger" data-mj-hp></div></div></div>
      <div class="fighter">
        <div class="sprite" style={`box-shadow:${RUNNER};`}></div>
        <span class="fist"></span>
      </div>
      <div class="page-boss" data-mj-beat>
        <div class="sprite" style={`box-shadow:${BOSS_PAGE};`}></div>
      </div>
      <div class="impact">✹</div>
    </>
  )}

  {/* LVL 7 — the dig: outrun the boulder, grab the relic on the way out */}
  {variant === 'dig' && (
    <>
      <div class="temple left"></div>
      <div class="temple right"></div>
      {['14%', '34%', '58%', '82%'].map((left, i) => (
        <div class="torch" style={`left:${left};animation-delay:${i * 0.4}s;`}></div>
      ))}
      {/* ruins: broken columns, vines and a watching idol */}
      {['20%', '44%', '68%', '90%'].map((left, i) => (
        <div class="column" style={`left:${left};height:${[30, 22, 34, 26][i]}px;`}></div>
      ))}
      {['28%', '52%', '76%'].map((left, i) => (
        <div class="vine" style={`left:${left};height:${[26, 34, 20][i]}px;animation-delay:${i * 0.5}s;`}></div>
      ))}
      <div class="idol" style="left:63%;"></div>
      <div class="relic" data-mj-beat>▽</div>
      <div class="boulder"></div>
      <div class="digger" data-mj-beat>
        <div class="sprite frame-a" style={`box-shadow:${ARCHEOLOGIST};`}></div>
        <div class="sprite frame-b" style={`box-shadow:${ARCHEOLOGIST_B};`}></div>
        <span class="whip"></span>
      </div>
    </>
  )}

  {variant === 'store' && (
    <div class="runner hopper" data-mj-vehicle>
      <div class="sprite" style={`box-shadow:${RUNNER};`}></div>
    </div>
  )}
</div>

<style>
  .strip {
    position: relative;
    overflow: hidden;
    height: var(--arcade-strip-h);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, var(--s0), var(--bg));
  }
  .label, .score {
    position: absolute;
    top: 14px;
    font-family: var(--font-mono);
    font-size: var(--text-caption-xs);
    letter-spacing: 0.24em;
  }
  .label { left: var(--section-pad-x); color: var(--muted2); max-width: 70%; }
  .score { right: var(--section-pad-x); color: var(--accent); font-variant-numeric: tabular-nums; }
  .pop {
    position: absolute;
    top: 72px;
    left: 0;
    opacity: 0;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: var(--text-small);
    color: var(--accent);
    pointer-events: none;
    white-space: nowrap;
  }
  .ground {
    position: absolute;
    left: 0; right: 0; bottom: 40px;
    height: 2px;
    background: repeating-linear-gradient(90deg, var(--border2) 0 12px, transparent 12px 24px);
  }
  .sprite { width: 6px; height: 6px; background: transparent; }

  /* ---------- LVL 1 ---------- */
  .coin {
    position: absolute;
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 700;
    line-height: 1;
    color: var(--accent);
    animation: mj-coin 1.7s ease-in-out infinite;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .collected { opacity: 0; transform: scale(2.2); }
  .obstacle { position: absolute; bottom: 42px; }
  .obstacle .sprite { width: 6px; height: 6px; }
  .obstacle-tag {
    position: absolute;
    top: -14px; left: 0;
    font-family: var(--font-mono); font-size: 8px; letter-spacing: 0.16em;
    color: var(--muted2); opacity: 0.7; white-space: nowrap;
  }
  .boss {
    position: absolute; bottom: 42px; right: 5%;
    width: 56px; height: 48px;
    transform-origin: bottom center;
    animation: mj-boss 1.4s ease-in-out infinite;
  }
  .boss .sprite { width: 8px; height: 8px; transition: transform 0.18s ease, opacity 0.35s ease; }
  .boss-tag {
    position: absolute; top: -16px; right: 0;
    font-family: var(--font-mono); font-size: 8px; letter-spacing: 0.16em;
    color: var(--danger); white-space: nowrap; transition: opacity 0.25s ease;
  }
  .boss.defeated { animation: none; }
  .boss.defeated .sprite { transform: translateY(26px) scaleY(0.12); opacity: 0; }
  .boss.defeated .boss-tag { opacity: 0; }
  .debris { position: absolute; left: 24px; top: 20px; width: 0; height: 0; }
  .debris i { position: absolute; width: 6px; height: 6px; background: #545a66; opacity: 0; }
  .boss.defeated .debris i { animation: mj-debris 0.65s ease-out forwards; transform: rotate(var(--a)) translateX(0); }
  .ko {
    position: absolute; left: 4px; top: -6px;
    font-family: var(--font-display); font-size: 20px; font-weight: 700;
    color: var(--danger); opacity: 0; pointer-events: none;
  }
  .boss.defeated .ko { animation: mj-ko 1s ease-out forwards; }
  .runner { position: absolute; top: 58px; left: 0; width: 48px; height: 60px; }
  .runner.hopper { animation: mj-level 15s linear infinite; }

  /* ---------- LVL 2 · Temple Run down the sprint ---------- */
  /* Perspective track: rails converge on a vanishing point at the top centre. */
  .track { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
  /* rails splay wide so the track fills ~80% of the strip at the near end */
  .track .rail {
    position: absolute; bottom: 0; left: 50%; width: 2px; height: 128px;
    background: linear-gradient(180deg, transparent, var(--level-scrum));
    opacity: 0.5; transform-origin: top center;
  }
  .track .rail.left { transform: rotate(52deg); }
  .track .rail.right { transform: rotate(-52deg); }
  /* sleepers sweeping toward the camera, widening as they come */
  .track .tie {
    position: absolute; top: 52px; left: 50%; height: 2px; width: 40px;
    margin-left: -20px; background: var(--level-scrum); opacity: 0.35;
    animation: mj-tie 2.8s linear infinite;
  }
  .sprint-tag {
    position: absolute; left: var(--section-pad-x); bottom: 18px;
    font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.2em; color: var(--muted2);
  }
  /* Ceremonies rush the camera from the vanishing point. */
  .onrush {
    position: absolute; top: 52px; left: 50%;
    white-space: nowrap;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em;
    padding: 3px 8px; border-radius: 4px;
    border: 1px solid var(--border3);
    background: var(--s2); color: var(--muted);
    transform-origin: center top;
    animation: mj-onrush 6.9s linear infinite;
  }
  .onrush.epic { border-color: var(--level-scrum); color: var(--level-scrum); }
  .onrush.intent {
    border-color: var(--accent); color: var(--accent);
    background: transparent; font-weight: 600;
  }
  /* nearest the camera, so the ceremonies sweep past behind him */
  .sprinter {
    position: absolute; bottom: 16px; left: 50%; margin-left: -24px;
    width: 48px; height: 60px;
    z-index: 3;
    filter: drop-shadow(0 6px 10px rgba(0, 0, 0, 0.7));
    animation: mj-strafe 6.9s ease-in-out infinite;
  }
  .sprinter .sprite { position: absolute; left: 0; top: 0; width: 6px; height: 6px; }
  .sprinter .frame-a { animation: mj-frame-a 0.22s steps(1, end) infinite; }
  .sprinter .frame-b { animation: mj-frame-b 0.22s steps(1, end) infinite; transform: scaleX(-1); transform-origin: center; }

  /* ---------- LVL 3 · rhythm ---------- */
  .lane {
    position: absolute; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--fret), transparent 78%);
    opacity: 0.22;
  }
  .strike {
    position: absolute; left: 16%; top: 44px; height: 92px; width: 3px;
    background: var(--text); opacity: 0.5; box-shadow: 0 0 12px var(--accent-2);
  }
  .strike-label {
    position: absolute; left: 16%; top: 30px; transform: translateX(-50%);
    font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.2em; color: var(--muted2);
  }
  .fret {
    position: absolute; left: 16%; transform: translateX(-50%);
    width: 12px; height: 12px; border-radius: 50%;
    border: 2px solid var(--fret); opacity: 0.75;
  }
  /* Notes travel in and stop at the strike line, where they are played. */
  .gem {
    position: absolute; right: -24px;
    width: 14px; height: 14px; border-radius: 3px;
    background: var(--fret); box-shadow: 0 0 10px var(--fret);
    animation: mj-note 7s linear infinite;
  }
  /* Guitarist stands just left of the hit bar with his guitar reaching it, so the
     notes are struck where he is actually playing. Clear of the edge, fully visible. */
  .guitarist {
    position: absolute; left: calc(16% - 82px); top: 56px;
    width: 48px; height: 60px;
    animation: mj-bob 1.9s ease-in-out infinite;
  }
  /* Slung across the chest at a player's angle: body low at the hip on the near
     side, neck rising away to the right. Sits over the torso, clear of the head. */
  .guitar {
    position: absolute; left: 8px; top: 26px; width: 46px; height: 22px;
    transform: rotate(-22deg);
    transform-origin: 14px 12px;
    animation: mj-strum 0.5s ease-in-out infinite;
  }
  /* Body against the torso, neck reaching out toward the notes — the way a guitar
     is actually held (it was mirrored before). */
  .guitar .body {
    position: absolute; left: 0; top: 1px; width: 20px; height: 20px;
    background: #c98b6a; border: 1px solid #8a5c42;
    border-radius: 54% 46% 40% 60% / 40% 40% 60% 60%;
    box-shadow: inset 3px 0 0 #a86f52;
  }
  .guitar .body::after {
    content: ''; position: absolute; left: 7px; top: 7px;
    width: 6px; height: 6px; border-radius: 50%; background: #4a3620;
  }
  .guitar .neck {
    position: absolute; left: 16px; top: 8px; width: 28px; height: 5px;
    background: #4a3620; border-radius: 1px;
  }
  /* strumming hand sits over the body, not up the neck */
  .guitar .strum {
    position: absolute; left: 6px; top: 6px; width: 8px; height: 2px;
    background: var(--accent); opacity: 0.95;
    animation: mj-pick 0.25s linear infinite;
  }

  /* ---------- LVL 4 · book round ---------- */
  .house { position: absolute; bottom: 42px; width: 40px; height: 46px; background: var(--s2); border: 2px solid var(--border3); border-bottom: 0; }
  .house .roof {
    position: absolute; left: -4px; top: -12px;
    border-left: 24px solid transparent; border-right: 24px solid transparent;
    border-bottom: 12px solid var(--level-books);
  }
  .house .door { position: absolute; left: 13px; bottom: 0; width: 14px; height: 20px; background: var(--bg); border: 1px solid var(--border3); border-bottom: 0; }
  /* the parcel arcs from the van's lane down to the doorstep */
  .parcel {
    position: absolute; left: 10px; top: -34px;
    font-size: 15px; line-height: 1; color: var(--level-books);
    opacity: 0;
    animation: mj-throw 7s ease-in infinite;
  }
  /* van sits on the road line (ground is at bottom:40px) rather than floating */
  .van { position: absolute; bottom: 42px; left: 0; width: 42px; height: 30px; animation: mj-run 7s linear infinite; }

  .scenery { position: absolute; bottom: 42px; }
  .scenery.tree { width: 0; height: 0; }
  .scenery.tree::before {
    content: ''; position: absolute; bottom: 0; left: -2px; width: 4px; height: 14px; background: #4a3620;
  }
  .scenery.tree::after {
    content: ''; position: absolute; bottom: 12px; left: -11px; width: 22px; height: 22px;
    border-radius: 50%; background: #2f6b45;
  }
  .scenery.bush { width: 0; height: 0; }
  .scenery.bush::after {
    content: ''; position: absolute; bottom: 0; left: -9px; width: 18px; height: 11px;
    border-radius: 9px 9px 0 0; background: #35583f;
  }
  .scenery.lamp { width: 0; height: 0; }
  .scenery.lamp::before {
    content: ''; position: absolute; bottom: 0; left: -1px; width: 3px; height: 34px; background: var(--border3);
  }
  .scenery.lamp::after {
    content: ''; position: absolute; bottom: 30px; left: -5px; width: 11px; height: 7px;
    border-radius: 4px; background: var(--accent); box-shadow: 0 0 14px var(--accent);
  }
  /* neighbour on the pavement, waving the van past */
  .waver { position: absolute; bottom: 42px; left: 68%; width: 12px; height: 30px; }
  .waver .head { position: absolute; bottom: 20px; left: 1px; width: 10px; height: 10px; border-radius: 50%; background: #e8c39a; }
  .waver .body { position: absolute; bottom: 0; left: 2px; width: 8px; height: 21px; background: var(--accent-2); border-radius: 2px; }
  .waver .arm {
    position: absolute; bottom: 18px; left: 10px; width: 9px; height: 3px;
    background: #e8c39a; border-radius: 2px;
    transform-origin: left center;
    animation: mj-wave 0.7s ease-in-out infinite;
  }

  /* ---------- LVL 5 · dodge ---------- */
  .spotlight {
    position: absolute; left: 50%; top: 0; width: 230px; margin-left: -115px; height: 100%;
    background: linear-gradient(180deg, rgba(224, 122, 154, 0.16), transparent 78%);
    clip-path: polygon(38% 0, 62% 0, 100% 100%, 0 100%);
    pointer-events: none;
  }
  .mic { position: absolute; left: calc(50% + 26px); bottom: 70px; width: 3px; height: 16px; background: var(--border3); }
  .mic::after { content: ''; position: absolute; top: -5px; left: -3px; width: 9px; height: 7px; border-radius: 50%; background: var(--level-stage); }
  .heckle {
    position: absolute;
    font-family: var(--font-display); font-size: 17px; font-weight: 700; line-height: 1;
    color: var(--level-stage);
  }
  .heckle.from-left { left: -30px; animation: mj-throw-right linear infinite; }
  .heckle.from-right { right: -30px; animation: mj-throw-left linear infinite; }
  .audience {
    position: absolute; left: 0; right: 0; bottom: 0; height: 34px;
    display: flex; align-items: flex-end; justify-content: space-around;
    padding: 0 var(--section-pad-x); pointer-events: none;
  }
  .audience span { width: 12px; height: 14px; border-radius: 6px 6px 0 0; background: var(--border2); animation: mj-bob 2.4s ease-in-out infinite; }
  /* centre stage at the mic, sidestepping the incoming questions */
  .runner.speaker {
    left: 50%;
    top: 54px;
    margin-left: -24px;
    animation: mj-dodge 3.1s ease-in-out infinite;
  }
  @keyframes mj-dodge {
    0%, 100% { transform: translateX(-34px); }
    25% { transform: translateX(-34px) translateY(-6px); }
    50% { transform: translateX(34px); }
    75% { transform: translateX(34px) translateY(-6px); }
  }

  /* ---------- LVL 6 · fight ---------- */
  .hp { position: absolute; top: 40px; font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.18em; color: var(--muted2); width: 140px; }
  .hp.you { left: var(--section-pad-x); }
  .hp.boss-hp { right: var(--section-pad-x); }
  .bar { margin-top: 4px; width: 100%; height: 7px; background: var(--border); border-radius: 4px; overflow: hidden; }
  .fill { width: 100%; height: 100%; }
  .fill.ok { background: var(--ok); }
  .fill.danger { background: var(--danger); transition: width 0.25s ease; }
  .fighter { position: absolute; top: 58px; left: 32%; width: 48px; height: 60px; animation: mj-lunge 1.9s ease-in-out infinite; }
  .fighter .fist {
    position: absolute; right: -6px; top: 26px; width: 10px; height: 8px;
    background: #e8c39a; opacity: 0;
    animation: mj-punch 1.9s ease-in-out infinite;
  }
  .page-boss {
    position: absolute; top: 56px; right: 32%; width: 40px; height: 48px;
    animation: mj-recoil 1.9s ease-in-out infinite;
  }
  .page-boss .sprite { width: 8px; height: 8px; }
  /* ringside dressing */
  .crowd {
    position: absolute; left: 0; right: 0; bottom: 0; height: 30px;
    display: flex; align-items: flex-end; justify-content: space-around;
    padding: 0 12px; pointer-events: none; opacity: 0.75;
  }
  .crowd span {
    width: 11px; height: 12px; border-radius: 6px 6px 0 0;
    background: var(--border2);
    animation: mj-bob 2.2s ease-in-out infinite;
  }
  .crowd span.tall { height: 17px; background: var(--border3); }
  .ring-light {
    position: absolute; top: 0; width: 90px; height: 62px; margin-left: -45px;
    background: linear-gradient(180deg, rgba(127, 201, 154, 0.16), transparent 85%);
    clip-path: polygon(42% 0, 58% 0, 100% 100%, 0 100%);
    animation: mj-flicker 2.6s ease-in-out infinite;
    pointer-events: none;
  }
  .banner {
    position: absolute; top: 22px; left: 50%; transform: translateX(-50%);
    font-family: var(--font-mono); font-size: 8px; letter-spacing: 0.2em;
    color: var(--muted2);
    border: 1px solid var(--border2); border-top: 0;
    padding: 3px 10px 4px; border-radius: 0 0 5px 5px;
    background: var(--s2);
  }
  .impact {
    position: absolute; left: 50%; top: 74px; transform: translate(-50%, 0) scale(0.5);
    font-family: var(--font-display); font-size: 30px; font-weight: 700; color: var(--danger);
    opacity: 0; pointer-events: none;
    animation: mj-impact 1.9s ease-in-out infinite;
  }

  /* ---------- LVL 7 · the dig ---------- */
  .temple {
    position: absolute; bottom: 42px; width: 46px; height: 74px;
    background: repeating-linear-gradient(180deg, #2a2a26 0 10px, #232320 10px 20px);
    border: 2px solid #3a3a33; border-bottom: 0;
  }
  .temple.left { left: 2%; }
  .temple.right { right: 2%; }
  .torch {
    position: absolute; bottom: 92px; width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 16px 4px rgba(224, 164, 74, 0.55);
    animation: mj-flicker 1.3s ease-in-out infinite;
  }
  .relic {
    position: absolute; bottom: 74px; left: 62%;
    font-size: 20px; line-height: 1; color: var(--level-dig);
    text-shadow: 0 0 12px var(--level-dig);
    animation: mj-relic 6s ease-in-out infinite;
  }
  .column {
    position: absolute; bottom: 42px; width: 12px;
    background: repeating-linear-gradient(180deg, #34332e 0 6px, #2b2a26 6px 12px);
    border: 1px solid #3f3d36; border-bottom: 0;
  }
  .vine {
    position: absolute; top: 0; width: 3px;
    background: linear-gradient(180deg, #2f5c3d, #3f7a4f);
    border-radius: 0 0 3px 3px;
    transform-origin: top center;
    animation: mj-sway 3.4s ease-in-out infinite;
  }
  .idol {
    position: absolute; bottom: 42px; width: 16px; height: 20px;
    background: #4a5b52; border: 1px solid #5d7166;
    border-radius: 3px 3px 0 0;
    box-shadow: inset 0 -4px 0 #3b4a42;
  }
  .idol::after {
    content: ''; position: absolute; left: 3px; top: 5px;
    width: 3px; height: 3px; background: var(--level-dig);
    box-shadow: 7px 0 0 var(--level-dig);
  }
  /* boulder chases from behind and closes the gap across the run */
  .boulder {
    position: absolute; bottom: 40px; left: -90px;
    width: 58px; height: 58px; border-radius: 50%;
    background: radial-gradient(circle at 35% 32%, #6a6258, #3b3730 70%);
    border: 2px solid #2b2822;
    box-shadow: 0 0 22px rgba(0, 0, 0, 0.6);
    animation: mj-boulder 6s linear infinite;
  }
  /* stays ahead of it — same clock, shorter distance, so the gap narrows */
  .digger { position: absolute; bottom: 42px; left: 40px; width: 48px; height: 60px; animation: mj-sprint 6s linear infinite; }
  .digger .sprite { position: absolute; left: 0; top: 0; width: 6px; height: 6px; }
  /* two-frame run cycle */
  .digger .frame-a { animation: mj-frame-a 0.26s steps(1, end) infinite; }
  .digger .frame-b { animation: mj-frame-b 0.26s steps(1, end) infinite; }
  .digger .whip {
    position: absolute; right: -16px; top: 26px; width: 18px; height: 2px;
    background: #6b4a2a; border-radius: 2px; transform-origin: left center;
    animation: mj-whip 0.9s ease-in-out infinite;
  }

  /* ---------- keyframes ---------- */
  @keyframes mj-flicker { 0%, 100% { opacity: 1; transform: scale(1); } 45% { opacity: 0.6; transform: scale(0.82); } }
  @keyframes mj-relic {
    0%, 62% { opacity: 1; transform: translateY(0) scale(1); }
    70% { opacity: 0; transform: translateY(-16px) scale(1.9); }
    71%, 100% { opacity: 0; transform: translateY(0) scale(1); }
  }
  @keyframes mj-boulder {
    from { transform: translateX(0) rotate(0); }
    to { transform: translateX(calc(100vw + 230px)) rotate(1080deg); }
  }
  /* shorter travel than the boulder over the same 6s, so it gains on him */
  @keyframes mj-sprint {
    0% { transform: translateX(0) translateY(0); }
    100% { transform: translateX(calc(100vw + 150px)) translateY(0); }
  }
  @keyframes mj-frame-a { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; } }
  @keyframes mj-frame-b { 0%, 49% { opacity: 0; } 50%, 100% { opacity: 1; } }
  @keyframes mj-sway { 0%, 100% { transform: rotate(-3deg); } 50% { transform: rotate(4deg); } }
  @keyframes mj-whip { 0%, 100% { transform: rotate(6deg); } 50% { transform: rotate(-26deg); } }
  @keyframes mj-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
  @keyframes mj-debris {
    0% { opacity: 1; transform: rotate(var(--a)) translateX(0); }
    100% { opacity: 0; transform: rotate(var(--a)) translateX(46px); }
  }
  @keyframes mj-ko {
    0% { opacity: 0; transform: translateY(6px) scale(0.6); }
    30% { opacity: 1; transform: translateY(-10px) scale(1.1); }
    100% { opacity: 0; transform: translateY(-30px) scale(1); }
  }
  @keyframes mj-level {
    0%   { transform: translateX(-60px) translateY(0); }
    32%  { transform: translateX(calc((100vw + 60px) * 0.32 - 60px)) translateY(0); }
    36%  { transform: translateX(calc((100vw + 60px) * 0.36 - 60px)) translateY(-34px); }
    40%  { transform: translateX(calc((100vw + 60px) * 0.40 - 60px)) translateY(0); }
    58%  { transform: translateX(calc((100vw + 60px) * 0.58 - 60px)) translateY(0); }
    62%  { transform: translateX(calc((100vw + 60px) * 0.62 - 60px)) translateY(-36px); }
    66%  { transform: translateX(calc((100vw + 60px) * 0.66 - 60px)) translateY(0); }
    82%  { transform: translateX(calc((100vw + 60px) * 0.82 - 60px)) translateY(0); }
    86%  { transform: translateX(calc((100vw + 60px) * 0.86 - 60px)) translateY(-30px); }
    90%  { transform: translateX(calc((100vw + 60px) * 0.90 - 60px)) translateY(0); }
    93%  { transform: translateX(calc((100vw + 60px) * 0.93 - 60px)) translateY(0); }
    96%  { transform: translateX(calc((100vw + 60px) * 0.96 - 60px)) translateY(-42px); }
    100% { transform: translateX(calc((100vw + 60px) * 1 - 60px)) translateY(0); }
  }
  @keyframes mj-blink-soft { 0%, 60% { opacity: 1; } 61%, 100% { opacity: 0.32; } }
  /* sleeper sweeps from the vanishing point to the camera, widening to ~80vw */
  @keyframes mj-tie {
    0% { transform: translateY(0) scaleX(0.2); opacity: 0; }
    12% { opacity: 0.4; }
    100% { transform: translateY(78px) scaleX(24); opacity: 0; }
  }
  /* ceremony grows out of the vanishing point and sweeps wide past the camera */
  @keyframes mj-onrush {
    0% { transform: translate(-50%, 0) translateX(0) scale(0.35); opacity: 0; }
    10% { opacity: 1; }
    82% { transform: translate(-50%, 62px) translateX(calc(var(--lane) * 26vw)) scale(1.15); opacity: 1; }
    100% { transform: translate(-50%, 82px) translateX(calc(var(--lane) * 40vw)) scale(1.5); opacity: 0; }
  }
  /* the sprinter shifts lane to meet whatever is arriving */
  @keyframes mj-strafe {
    0%, 12% { transform: translateX(0); }
    28% { transform: translateX(-24vw); }
    45% { transform: translateX(24vw); }
    62% { transform: translateX(0); }
    78% { transform: translateX(-24vw); }
    95%, 100% { transform: translateX(24vw); }
  }
  @keyframes mj-wave { 0%, 100% { transform: rotate(-8deg); } 50% { transform: rotate(-58deg); } }
  /* Note slides in from the right and lands exactly on the 16% hit bar.
     Gem starts at right:-24px, so its left edge sits at (100vw + 10px);
     travelling -84vw - 10px puts it dead on 16vw. */
  @keyframes mj-note {
    0% { transform: translateX(0); opacity: 0; }
    4% { opacity: 1; }
    86% { transform: translateX(calc(-84vw - 10px)); opacity: 1; }
    92% { transform: translateX(calc(-84vw - 10px)) scale(2.2); opacity: 0.35; }
    100% { transform: translateX(calc(-84vw - 10px)) scale(1); opacity: 0; }
  }
  /* keep the slung angle; only breathe slightly, so nothing swings about */
  @keyframes mj-strum { 0%, 100% { transform: rotate(-22deg); } 50% { transform: rotate(-19deg); } }
  @keyframes mj-pick { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(5px); } }
  @keyframes mj-run { from { transform: translateX(-60px); } to { transform: translateX(102vw); } }
  /* parcel appears as the van passes the house, arcs down to the door */
  @keyframes mj-throw {
    0%, 8% { opacity: 0; transform: translate(0, 0) rotate(0); }
    10% { opacity: 1; transform: translate(-6px, -6px) rotate(-40deg); }
    18% { opacity: 1; transform: translate(4px, 30px) rotate(140deg); }
    24%, 100% { opacity: 1; transform: translate(4px, 34px) rotate(180deg); }
  }
  @keyframes mj-throw-right {
    0% { transform: translateX(0) rotate(0); opacity: 0; }
    10%, 85% { opacity: 1; }
    100% { transform: translateX(calc(100vw + 60px)) rotate(540deg); opacity: 0; }
  }
  @keyframes mj-throw-left {
    0% { transform: translateX(0) rotate(0); opacity: 0; }
    10%, 85% { opacity: 1; }
    100% { transform: translateX(calc(-100vw - 60px)) rotate(-540deg); opacity: 0; }
  }
  @keyframes mj-lunge {
    0%, 55%, 100% { transform: translateX(0); }
    35% { transform: translateX(26px); }
  }
  @keyframes mj-punch {
    0%, 28%, 55%, 100% { opacity: 0; transform: translateX(0); }
    35%, 45% { opacity: 1; transform: translateX(10px); }
  }
  @keyframes mj-recoil {
    0%, 30%, 100% { transform: translateX(0) rotate(0); }
    40% { transform: translateX(16px) rotate(6deg); }
    60% { transform: translateX(4px) rotate(0); }
  }
  @keyframes mj-impact {
    0%, 32%, 60%, 100% { opacity: 0; transform: translate(-50%, 0) scale(0.5); }
    38%, 48% { opacity: 1; transform: translate(-50%, 0) scale(1.25) rotate(12deg); }
  }
  @keyframes mj-coin { 0%, 100% { transform: translateY(0) scaleX(1); } 25% { transform: translateY(-7px) scaleX(0.25); } 50% { transform: translateY(0) scaleX(1); } 75% { transform: translateY(-7px) scaleX(0.25); } }
  @keyframes mj-boss { 0%, 100% { transform: translateY(0) scaleX(1); } 50% { transform: translateY(-7px) scaleX(1.06); } }
</style>

<script>
  // Score + level-1 stomp. Points come from CSS animation cycles (`data-mj-beat`),
  // so the number always moves in step with what is actually on screen. Runs only
  // while the strip is visible, and not at all under prefers-reduced-motion.
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduced) {
    const POINTS: Record<string, number> = { store: 100, scrum: 100, artist: 100, books: 150, stage: 50, notes: 120, dig: 250 };
    const CALLOUT: Record<string, string> = {
      scrum: 'SHIPPED +100',
      artist: 'PERFECT +100',
      books: 'DELIVERED +150',
      stage: 'DODGED +50',
      notes: 'HIT +120',
      dig: 'RELIC +250',
    };

    document.querySelectorAll<HTMLElement>('[data-mj-strip]').forEach((strip) => {
      const kind = strip.dataset.mjStrip!;
      const scoreEl = strip.querySelector<HTMLElement>('[data-mj-score]');
      const popEl = strip.querySelector<HTMLElement>('[data-mj-pop]');
      const hpEl = strip.querySelector<HTMLElement>('[data-mj-hp]');
      let score = 0;
      let hp = 100;
      let visible = false;

      const render = () => {
        if (scoreEl) scoreEl.textContent = 'SCORE ' + String(Math.min(score, 999999)).padStart(6, '0');
      };
      const pop = (x: number, text: string, color: string) => {
        if (!popEl) return;
        popEl.textContent = text;
        popEl.style.color = color;
        popEl.style.left = Math.max(8, x) + 'px';
        popEl.style.transition = 'none';
        popEl.style.opacity = '1';
        popEl.style.transform = 'translateY(0)';
        requestAnimationFrame(() => {
          popEl.style.transition = 'opacity .7s ease, transform .7s ease';
          popEl.style.opacity = '0';
          popEl.style.transform = 'translateY(-26px)';
        });
      };
      render();

      // Every completed animation cycle of a scoring element = one play.
      strip.querySelectorAll<HTMLElement>('[data-mj-beat]').forEach((el) => {
        el.addEventListener('animationiteration', () => {
          if (!visible) return;
          score += POINTS[kind] ?? 100;
          render();
          const box = strip.getBoundingClientRect();
          const r = el.getBoundingClientRect();
          const colour = getComputedStyle(el).backgroundColor;
          pop(r.left - box.left - 16, CALLOUT[kind] ?? '+100', colour.includes('rgba(0, 0, 0, 0)') ? getComputedStyle(el).color : colour);
          if (kind === 'notes' && hpEl) {
            hp = hp <= 20 ? 100 : hp - 20;
            hpEl.style.width = hp + '%';
          }
        });
      });

      // Level 1 keeps real collision: coins picked up and the boss stomped.
      const vehicle = strip.querySelector<HTMLElement>('[data-mj-vehicle]');
      const pickups = [...strip.querySelectorAll<HTMLElement>('[data-mj-collect]')];
      const boss = strip.querySelector<HTMLElement>('[data-mj-boss]');
      let lastX = -1e9;
      let timer: number | undefined;

      const tick = () => {
        if (!vehicle) return;
        const box = strip.getBoundingClientRect();
        const v = vehicle.getBoundingClientRect();
        const vx = v.left - box.left;
        if (vx < lastX) {
          pickups.forEach((p) => p.classList.remove('collected'));
          boss?.classList.remove('defeated');
        }
        lastX = vx;
        for (const p of pickups) {
          if (p.classList.contains('collected')) continue;
          const r = p.getBoundingClientRect();
          if (v.right > r.left && v.left < r.right) {
            p.classList.add('collected');
            score += 100;
            render();
            pop(r.left - box.left - 12, '+100', getComputedStyle(p).color);
          }
        }
        if (boss && !boss.classList.contains('defeated')) {
          const b = boss.getBoundingClientRect();
          if (v.right > b.left && v.left < b.right) {
            boss.classList.add('defeated');
            score += 500;
            render();
            pop(b.left - box.left - 10, 'K.O. +500', '#e05a48');
          }
        }
      };

      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            visible = e.isIntersecting;
            if (visible && vehicle && !timer) timer = window.setInterval(tick, 110);
            if (!visible && timer) { window.clearInterval(timer); timer = undefined; }
          }
        },
        { rootMargin: '80px 0px' },
      );
      io.observe(strip);
    });
  }
</script>
