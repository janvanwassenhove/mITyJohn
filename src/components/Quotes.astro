---
// "Words to build by" — three tinted quote cards, design content verbatim,
// with mITy.John listening in at the side.
import { MITYJOHN } from './sprites';

// One mITy.John per card, each reacting differently: sketching an idea,
// charging ahead, waving the team over.
const quotes = [
  {
    pose: 'idea',
    aside: 'noted.',
    kicker: 'Creative',
    text: 'A true architect is not an artist but an optimistic realist. He takes a diverse number of stakeholders, extracts needs, concerns and dreams, then creates a beautiful yet tangible solution loved by the users and the community at large. He creates vessels in which life happens.',
    who: 'Cameron Sinclair',
    accent: '#e0a44a',
    tint: 'rgba(224,164,74,0.08)',
  },
  {
    pose: 'go',
    aside: 'already did it.',
    kicker: 'Practice',
    text: 'If it’s a good idea, go ahead and do it. It is much easier to apologize than it is to get a permission.',
    who: 'Grace Hopper',
    accent: '#c98b6a',
    tint: 'rgba(201,139,106,0.09)',
  },
  {
    pose: 'team',
    aside: 'who else is in?',
    kicker: 'Engaging',
    text: 'Invest in your professional development. Specialize… and team up with colleagues who have different strengths.',
    who: 'Melissa Milloway',
    accent: '#6fb3c9',
    tint: 'rgba(111,179,201,0.08)',
  },
];
---

<section class="quotes">
  <div class="wrap">
    <div class="kicker">// words to build by</div>
    <div class="grid">
      {quotes.map((q) => (
        <figure data-reveal style={`--q-accent:${q.accent};--q-tint:${q.tint};`}>
          <div class="mark">&ldquo;</div>
          <div class="label">{q.kicker}</div>
          <div class="mj-wrap" aria-hidden="true">
            <div class={`mj ${q.pose} mj-anim`}>
              <span class="sprite" style={`box-shadow:${MITYJOHN};`}></span>
              {q.pose === 'idea' && <span class="bulb"></span>}
              {q.pose === 'go' && <span class="fist"></span>}
              {q.pose === 'team' && <span class="wave"></span>}
              <span class="aside">{q.aside}</span>
            </div>
          </div>
          <blockquote>{q.text}</blockquote>
          <div class="rule"></div>
          <figcaption>{q.who}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .quotes { border-top: 1px solid var(--line); background: var(--s0); }
  .wrap { max-width: var(--container-max); margin: 0 auto; padding: clamp(40px, 5vw, 68px) var(--section-pad-x); }
  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--accent);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 28px;
  }

  /* one mITy.John per card, each reacting to the quote in his own way */
  /* Scaling lives on the wrapper so it can't fight the pose animations, which
     drive transform on .mj itself. Negative margins claw back the layout space
     the scale leaves behind. */
  .mj-wrap {
    transform: scale(0.8);
    transform-origin: center top;
    margin: -6px 0 -18px;
  }
  .mj {
    position: relative;
    width: 48px;
    height: 62px;
    transform-origin: bottom center;
  }
  .mj .sprite { position: absolute; left: 0; top: 0; width: 6px; height: 6px; background: transparent; }
  .mj .aside {
    position: absolute;
    left: 50%;
    bottom: -14px;
    transform: translateX(-50%);
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--q-accent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  figure:hover .aside { opacity: 1; }

  /* pose 1 — sketching: leans in, lightbulb pops above */
  .mj.idea { animation: mj-think 3.4s ease-in-out infinite; }
  .mj.idea .bulb {
    position: absolute; left: 34px; top: -8px;
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
    animation: mj-ping 2.2s ease-in-out infinite;
  }
  /* pose 2 — charging ahead: bounces forward, fist up */
  .mj.go { animation: mj-charge 1.5s ease-in-out infinite; }
  .mj.go .fist {
    position: absolute; left: 42px; top: 14px;
    width: 9px; height: 8px; border-radius: 2px; background: #e8c39a;
    animation: mj-raise 1.5s ease-in-out infinite;
  }
  /* pose 3 — waving the team over */
  .mj.team { animation: mj-bob 2.6s ease-in-out infinite; }
  .mj.team .wave {
    position: absolute; left: 42px; top: 22px;
    width: 11px; height: 3px; border-radius: 2px; background: #e8c39a;
    transform-origin: left center;
    animation: mj-hail 0.8s ease-in-out infinite;
  }

  @keyframes mj-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
  @keyframes mj-think {
    0%, 100% { transform: rotate(0) translateY(0); }
    50% { transform: rotate(-4deg) translateY(-3px); }
  }
  @keyframes mj-charge {
    0%, 100% { transform: translateX(0) translateY(0); }
    40% { transform: translateX(5px) translateY(-7px); }
    70% { transform: translateX(2px) translateY(0); }
  }
  @keyframes mj-ping {
    0%, 60%, 100% { opacity: 0.35; transform: scale(0.8); }
    75% { opacity: 1; transform: scale(1.15); }
  }
  @keyframes mj-raise {
    0%, 100% { transform: translateY(0); }
    40% { transform: translateY(-9px); }
  }
  @keyframes mj-hail { 0%, 100% { transform: rotate(-6deg); } 50% { transform: rotate(-52deg); } }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: clamp(18px, 2vw, 26px); }
  figure {
    margin: 0;
    position: relative;
    color: var(--text);
    background: var(--s1);
    border: 1px solid var(--border);
    border-radius: var(--radius-panel);
    padding: clamp(30px, 3vw, 42px) clamp(24px, 2.5vw, 34px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 18px;
    transition: background 0.35s ease, border-color 0.35s ease, transform 0.35s ease, box-shadow 0.35s ease;
  }
  figure:hover { background: var(--q-tint); border-color: var(--q-accent); transform: translateY(-5px); box-shadow: var(--shadow-panel-hover); }
  .mark { font-family: var(--font-display); font-size: 64px; line-height: 0.42; font-weight: 700; color: var(--q-accent); }
  .label {
    font-family: var(--font-display);
    font-size: clamp(16px, 1.6vw, 21px);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--q-accent);
  }
  blockquote {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.62;
    max-width: 34ch;
    flex: 1;
    text-wrap: pretty;
  }
  .rule { width: 46px; height: 3px; border-radius: 2px; background: var(--q-accent); }
  figcaption {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted2);
  }
</style>
