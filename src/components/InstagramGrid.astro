---
// Instagram grid — reads build-time src/data/instagram.json (§7.3). Renders
// nothing when the feed is empty (N4: no runtime dependency on Instagram).
import feed from '../data/instagram.json';
import SectionHeader from './SectionHeader.astro';
import ArcadeStrip from './ArcadeStrip.astro';

type Item = { tag?: string; href: string; image?: string; alt?: string };
const all = feed as Item[];
const items = all.slice(0, 12); // two rows of six
---

{items.length > 0 && (
  <>
  <ArcadeStrip variant="dig" />
  <section class="ig" id="dig">
    <div class="wrap">
      <SectionHeader
        level="07"
        section="THE DIG"
        accentVar="var(--level-dig)"
        inkVar="var(--ink-on-level-dig)"
        title="Retro-IT, one square at a time"
      />
      <div class="head">
        <p class="note">Field finds from computing's past, posted daily-ish.</p>
        <a href="https://www.instagram.com/mity.john/" target="_blank" rel="noopener">@mity.john →</a>
      </div>
      <div class="grid">
        {items.map((g) => (
          <a class="tile" data-reveal href={g.href} target="_blank" rel="noopener">
            {g.image && <img src={g.image} alt={g.alt ?? ''} loading="lazy" decoding="async" />}
            {g.tag && <span>{g.tag}</span>}
          </a>
        ))}
      </div>
      {/* the grid is a slice of the feed, so the trail runs into the one CTA */}
      <div class="cta">
        <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
        <a class="follow" href="https://www.instagram.com/mity.john/" target="_blank" rel="noopener">
          Follow @mity.john on Instagram →
        </a>
        <p class="cta-note">A new find most days. No algorithm required.</p>
      </div>
    </div>
  </section>
  </>
)}

<style>
  .ig { border-top: 1px solid var(--line); background: var(--s0); }
  .wrap { max-width: var(--container-max); margin: 0 auto; padding: clamp(36px, 5vw, 64px) var(--section-pad-x); }
  .head { display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; margin: 10px 0 24px; }
  .note { font-family: var(--font-mono); font-size: var(--text-small); color: var(--muted2); margin: 0; }
  .head a { font-family: var(--font-mono); font-size: var(--text-small); }
  /* two rows of six on desktop, degrading to 4 / 3 / 2 as it narrows */
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: var(--gap-tiles); }
  @media (min-width: 900px) { .grid { grid-template-columns: repeat(6, 1fr); } }

  .cta { display: flex; flex-direction: column; align-items: center; gap: 12px; margin-top: 24px; }
  .follow {
    display: inline-block;
    padding: 12px 22px;
    border-radius: var(--radius-pill);
    background: var(--level-dig);
    color: var(--ink-on-level-dig);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 600;
    transition: filter var(--hover-duration) var(--hover-ease), transform var(--hover-duration) var(--hover-ease);
  }
  .follow:hover { filter: brightness(1.08); transform: translateY(-2px); }
  .cta-note { font-family: var(--font-mono); font-size: var(--text-caption-xs); color: var(--muted2); margin: 0; }
  .cta .dots { display: flex; gap: 5px; }
  .cta .dots i {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--level-dig); opacity: 0.25;
    animation: mj-trail 1.6s ease-in-out infinite;
  }
  .cta .dots i:nth-child(2) { animation-delay: 0.2s; }
  .cta .dots i:nth-child(3) { animation-delay: 0.4s; }
  @keyframes mj-trail { 0%, 100% { opacity: 0.2; transform: scale(0.85); } 50% { opacity: 1; transform: scale(1); } }
  @media (prefers-reduced-motion: reduce) {
    .cta .dots i { animation: none; opacity: 0.6; }
    .follow:hover { transform: none; }
  }
  .tile {
    position: relative;
    aspect-ratio: 1;
    border-radius: var(--radius-cover);
    border: 1px solid var(--border);
    background: repeating-linear-gradient(135deg, #1b1815 0 10px, #171410 10px 20px);
    display: flex;
    align-items: flex-end;
    padding: 12px;
    color: var(--text);
    overflow: hidden;
    transition: transform var(--hover-duration) var(--hover-ease), border-color var(--hover-duration) var(--hover-ease);
  }
  :root[data-theme='light'] .tile { background: repeating-linear-gradient(135deg, #e9e3d4 0 10px, #efeadd 10px 20px); }
  .tile:hover { border-color: var(--accent); transform: translateY(-4px) scale(1.02); color: var(--text); }
  .tile img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tile span { position: relative; font-family: var(--font-mono); font-size: var(--text-caption); font-weight: 600; text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6); }
</style>
